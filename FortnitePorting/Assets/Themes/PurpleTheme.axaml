<controls:FPStyles xmlns="https://github.com/avaloniaui"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:controls="clr-namespace:FortnitePorting.Controls">
    <controls:FPStyles.Resources>
        <Brush x:Key="FPSeparatorColorLayer1">#7700c7</Brush>
        <Brush x:Key="FPSeparatorColorLayer2">#7700c7</Brush>
             
        <Brush x:Key="FPButtonBackground">#7700c7</Brush>
        <Brush x:Key="FPButtonBackgroundPointerOver">#7700c7</Brush>
        <Brush x:Key="FPButtonBackgroundPressed">#7700c7</Brush>
        <Brush x:Key="FPButtonBorderBrush">#7700c7</Brush>
             
        <Brush x:Key="FPLayer2">#7700c7</Brush>
        <Brush x:Key="FPLayer2PointerOver">#7700c7</Brush>
        <Brush x:Key="FPLayer2Pressed">#7700c7</Brush>
             
        <Brush x:Key="FPButtonBackgroundSelected">#7700c7</Brush>
        <Brush x:Key="FPButtonBackgroundSelectedPointerOver">#7700c7</Brush>
             
        <Brush x:Key="FPButtonBackgroundBright">#7700c7</Brush>
        <Brush x:Key="FPButtonBackgroundBrightPointerOver">#7700c7</Brush>
    
        <LinearGradientBrush x:Key="FPContentCardBackground" StartPoint="0%, 0%" EndPoint="0%, 100%">
            <GradientStops>
                <GradientStop Color="#7700c7" Offset="0"/>
                <GradientStop Color="#7700c7" Offset="1"/>
            </GradientStops>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="FPPopupContentCardBackground" StartPoint="0%, 0%" EndPoint="0%, 100%">
            <GradientStops>
                <GradientStop Color="#7700c7" Offset="0"/>
                <GradientStop Color="#7700c7" Offset="1"/>
            </GradientStops>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="FPContentCardBackgroundBright" StartPoint="0%, 0%" EndPoint="0%, 100%">
            <GradientStops>
                <GradientStop Color="#3A1C21" Offset="0"/>
                <GradientStop Color="#2E161A" Offset="1"/>
            </GradientStops>
        </LinearGradientBrush>
        
        <SolidColorBrush x:Key="TextFillPrimaryBrush" Color="rgb(255, 255, 255)" />
        <SolidColorBrush x:Key="TextFillPrimaryDisabledBrush" Color="#ffffffea" />

        <SolidColorBrush x:Key="TextFillSecondaryBrush" Color="#ffffff" />
        <SolidColorBrush x:Key="TextFillSecondaryDisabledBrush" Color="#ffffffb5" />

        <SolidColorBrush x:Key="TextFillTertiaryBrush" Color="#ffffff" />
        <SolidColorBrush x:Key="TextFillTertiaryDisabledBrush" Color="#808C6B71" />
        
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#7700c7" />
        <SolidColorBrush x:Key="ContentBorderBackgroundBrush" Color="#7700c7" />
        <SolidColorBrush x:Key="ContentBorderBorderBrush" Color="#7700c7" />
        
        <SolidColorBrush x:Key="ContentBorderLayer2BackgroundBrush" Color="#7700c7" />
        <SolidColorBrush x:Key="ContentBorderLayer2BorderBrush" Color="#7700c7" />
        
        <SolidColorBrush x:Key="DialogOverlayBackgroundBrush" Color="#7700c7" />
        <SolidColorBrush x:Key="BroadcastOverlayBackgroundBrush" Color="#7700c7" />
        
        <SolidColorBrush x:Key="FPTitleTextBrush" Color="#7700c7" />
        <Color x:Key="FPAccentColor">#c38fe6</Color>
        <SolidColorBrush x:Key="FPAccentBrush" Color="{DynamicResource FPAccentColor}" />
        
        <Bitmap x:Key="FPLogoBitmap">avares://FortnitePorting/Assets/LogoRebrand.png</Bitmap>

    </controls:FPStyles.Resources>

</controls:FPStyles>